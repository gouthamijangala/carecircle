# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
ENV=development
DEMO_DEFAULT_PHONE=+919876543211

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_URL=
SUPABASE_KEY=

# ---------------------------------------------------------------------------
# LLM
# ---------------------------------------------------------------------------
LLM_ENDPOINT=http://127.0.0.1:1234/v1
LLM_MODEL=qwen/qwen3-4b
LLM_TIMEOUT=30
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=800
LLM_EXTRACTION_PRIMARY=http://127.0.0.1:1234/v1
LLM_EXTRACTION_PRIMARY_MODEL=qwen/qwen3-4b
LLM_EXTRACTION_FALLBACK=https://openrouter.ai/api/v1
LLM_EXTRACTION_FALLBACK_MODEL=
LLM_EXTRACTION_API_KEY=

# ---------------------------------------------------------------------------
# Embeddings and intent routing
# ---------------------------------------------------------------------------
EMBEDDING_ENABLED=false
EMBEDDING_PRELOAD_ON_STARTUP=false
EMBEDDING_AUTO_INSTALL_DEPENDENCIES=false

# ---------------------------------------------------------------------------
# OCR / media extraction
# ---------------------------------------------------------------------------
ENABLE_HYBRID_PDF_EXTRACTION=true
PADDLEOCR_USE_GPU=false
PADDLEOCR_LANG=en
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ---------------------------------------------------------------------------
# PharmaAgent
# ---------------------------------------------------------------------------
PHARMA_AGENT_ENABLED=true
PHARMAGENT_ENABLED=true
PHARMA_RESEARCH_ENABLED=true
PHARMA_TASK_POLLER_ENABLED=true
PHARMA_EXTERNAL_INTERACTION_LOOKUP_ENABLED=true
RXNAV_INTERACTION_API_ENABLED=true

# ---------------------------------------------------------------------------
# Notifications
# ---------------------------------------------------------------------------
NOTIFICATION_DISPATCH_ENABLED=false
NOTIFICATION_AUDIT_ONLY=true
NOTIFICATION_OUTBOX_ENABLED=true
APPRISE_ENABLED=false
APPRISE_URLS=

# ---------------------------------------------------------------------------
# Care coordination
# ---------------------------------------------------------------------------
DAILY_SUMMARY_ENABLED=true
APPOINTMENT_REMINDERS_ENABLED=true
CRISIS_FAST_PATH_ENABLED=true
CRISIS_OSM_LOOKUP_ENABLED=false

